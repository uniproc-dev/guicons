<idea-plugin>
    <id>dev.guicons.idea-plugin</id>
    <name>guicons</name>
    <vendor>guicons</vendor>

    <description><![CDATA[
        Native icon preview for guicons' <code>icon!</code>/<code>icon_key!</code>/<code>icon_data!</code>
        macro calls - shows the resolved icon directly in the Quick Documentation
        popup (Ctrl+Q / F1), instead of just a text description like the LSP's
        own hover already provides.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.jetbrains.rust</depends>

    <extensions defaultExtensionNs="com.intellij">
        <lang.documentationProvider
            language="Rust"
            implementationClass="dev.guicons.ideaplugin.GuiconsDocumentationProvider"/>
        <!-- Handles the string-literal argument case (icon!("family/variant"))
             that the legacy documentationProvider above never gets offered -
             see GuiconsPsiDocumentationTargetProvider's doc comment for why. -->
        <platform.backend.documentation.psiTargetProvider
            implementation="dev.guicons.ideaplugin.GuiconsPsiDocumentationTargetProvider"/>
    </extensions>

    <actions>
        <!-- Overrides Ctrl+Q/F1 itself - see GuiconsQuickDocAction's doc
             comment for why the two providers above still aren't enough
             for a string-literal macro argument. -->
        <action id="QuickJavaDoc" class="dev.guicons.ideaplugin.GuiconsQuickDocAction" overrides="true"/>

        <action id="dev.guicons.idea-plugin.OpenIconBrowser"
                class="dev.guicons.ideaplugin.OpenIconBrowserAction"
                text="Browse Guicons Icons...">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
